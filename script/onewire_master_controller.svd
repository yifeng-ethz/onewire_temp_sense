<?xml version="1.0" encoding="UTF-8"?>
<device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Mu3e</vendor>
  <vendorID>MU3E</vendorID>
  <name>MU3E_ONEWIRE_MASTER_CONTROLLER</name>
  <series>MU3E_FPGA_IP</series>
  <version>26.2.0</version>
  <description>CMSIS-SVD description of the onewire_master_controller CSR aperture. BaseAddress is 0 because this file describes the relative CSR aperture of the IP; system integration supplies the live slave base address.</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>
  <peripherals>
    <peripheral>
      <name>ONEWIRE_MASTER_CONTROLLER_CSR</name>
      <description>Relative 11-word 1-Wire controller CSR aperture with common Mu3e UID/META header.</description>
      <groupName>MU3E_ONEWIRE</groupName>
      <baseAddress>0x0</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x2C</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>UID</name>
          <description>Common Mu3e software-visible IP identifier. Default is ASCII OWMC.</description>
          <addressOffset>0x00</addressOffset>
          <access>read-only</access>
          <resetValue>0x4F574D43</resetValue>
          <fields>
            <field>
              <name>ip_uid</name>
              <description>HDL parameter IP_UID.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>META</name>
          <description>Common read-multiplexed metadata word. Writes select the readback page: 0 VERSION, 1 VERSION_DATE, 2 VERSION_GIT, 3 INSTANCE_ID.</description>
          <addressOffset>0x04</addressOffset>
          <access>read-write</access>
          <fields>
            <field>
              <name>selector</name>
              <description>Write page selector. 0 VERSION, 1 VERSION_DATE, 2 VERSION_GIT, 3 INSTANCE_ID.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>payload</name>
              <description>Readback payload for the selected metadata page. VERSION page encoding is MAJOR[31:24], MINOR[23:16], PATCH[15:12], BUILD[11:0].</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SCRATCH</name>
          <description>Software scratch/readback word for CSR liveness tests.</description>
          <addressOffset>0x08</addressOffset>
          <access>read-write</access>
          <fields>
            <field>
              <name>value</name>
              <description>Read/write scratchpad value, reset to zero.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CAPABILITY</name>
          <description>1-Wire controller capability register.</description>
          <addressOffset>0x0C</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>n_dq_lines</name>
              <description>Number of 1-Wire DQ lines synthesized into this instance.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>n_sensors</name>
              <description>Reserved for future successful Read-ROM probe count; currently reads zero.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>Line select and per-line control/status register. Reads return the selected line and its sticky error summary. Writes update sel_line and processor_go for the addressed line.</description>
          <addressOffset>0x10</addressOffset>
          <access>read-write</access>
          <fields>
            <field>
              <name>sel_line</name>
              <description>Selected DQ line index for readback and processor_go writes.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>processor_go</name>
              <description>Enable or disable the background measurement processor for the selected line.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved0</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>crc_err</name>
              <description>CRC error sticky flag for the selected line. Current RTL declaration is present; final CRC checker hookup remains a planned DV feature.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>init_err</name>
              <description>Initialization error sticky flag for the selected line.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>sample_valid</name>
              <description>Full DS18B20 scratchpad has been captured for the selected line after reset or the latest read transaction started.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>reserved1</name>
              <description>Reserved for planned Read-ROM probe status, read as zero in the current RTL.</description>
              <bitOffset>27</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SENSOR0_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 0.</description>
          <addressOffset>0x14</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 0.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
        <register>
          <name>SENSOR1_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 1.</description>
          <addressOffset>0x18</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 1.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
        <register>
          <name>SENSOR2_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 2.</description>
          <addressOffset>0x1C</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 2.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
        <register>
          <name>SENSOR3_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 3.</description>
          <addressOffset>0x20</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 3.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
        <register>
          <name>SENSOR4_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 4.</description>
          <addressOffset>0x24</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 4.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
        <register>
          <name>SENSOR5_TEMP_F32</name>
          <description>IEEE-754 float32 temperature reading for sensor 5.</description>
          <addressOffset>0x28</addressOffset>
          <access>read-only</access>
          <fields><field><name>value</name><description>Raw float32 temperature sample for sensor 5.</description><bitOffset>0</bitOffset><bitWidth>32</bitWidth><access>read-only</access></field></fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
